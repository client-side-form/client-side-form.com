<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | Client-Side Form{% else %}Client-Side Form State & Validation Architecture{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Production-ready architectural patterns for building robust client-side forms — state lifecycles, schema validation, cross-field logic, and framework adapters.{% endif %}">

  {# PWA / Icons #}
  <link rel="manifest" href="/manifest.json">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/assets/icons/logo.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="ClientSideForm">
  <meta name="theme-color" content="#1a1a3e">
  <meta name="mobile-web-app-capable" content="yes">

  {# SEO #}
  <meta name="robots" content="index, follow">
  {% if page.url %}<link rel="canonical" href="https://www.client-side-form.com{{ page.url }}">{% endif %}
  <link rel="sitemap" type="application/xml" href="/sitemap.xml">

  {# Open Graph #}
  {% if title %}{% set _ogTitle = title + " | Client-Side Form" %}{% else %}{% set _ogTitle = "Client-Side Form State & Validation Architecture" %}{% endif %}
  {% set _ogDesc = description if description else "Production-ready architectural patterns for building robust client-side forms." %}
  <meta property="og:title" content="{{ _ogTitle }}">
  <meta property="og:description" content="{{ _ogDesc }}">
  <meta property="og:type" content="{% if pageType == 'article' %}article{% else %}website{% endif %}">
  {% if page.url %}<meta property="og:url" content="https://www.client-side-form.com{{ page.url }}">{% endif %}
  <meta property="og:image" content="https://www.client-side-form.com/assets/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="ClientSideForm">

  {# Twitter / X Card #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ _ogTitle }}">
  <meta name="twitter:description" content="{{ _ogDesc }}">
  <meta name="twitter:image" content="https://www.client-side-form.com/assets/og-image.png">

  {# JSON-LD Structured Data #}
  {% if page.url %}
  {{ page.url | pageJsonLd(collections.all, title, description, pageType) | safe }}
  {% endif %}

  {# Stylesheets #}
  <link rel="stylesheet" href="/assets/css/main.css?v={{ assets.mainCss }}">
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  {# ===== HEADER ===== #}
  <header class="site-header" role="banner">
    <div class="header-inner">
      <a href="/" class="site-logo" aria-label="Client-Side Form home">
        <img src="/assets/icons/logo.svg" alt="" width="36" height="36">
        <span>ClientSideForm</span>
      </a>

      <button class="nav-toggle" aria-controls="site-nav" aria-expanded="false" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>

      <nav id="site-nav" class="site-nav" aria-label="Main navigation">
        <a href="/form-state-fundamentals-architecture/"
           class="nav-link{% if page.url | startsWith('/form-state-fundamentals-architecture') %} active{% endif %}"
           {% if page.url | startsWith('/form-state-fundamentals-architecture') %}aria-current="page"{% endif %}>
          <span class="nav-icon">📐</span> Form State
        </a>
        <a href="/framework-adapters-custom-hooks/"
           class="nav-link{% if page.url | startsWith('/framework-adapters-custom-hooks') %} active{% endif %}"
           {% if page.url | startsWith('/framework-adapters-custom-hooks') %}aria-current="page"{% endif %}>
          <span class="nav-icon">🔌</span> Framework Adapters
        </a>
        <a href="/validation-logic-schema-integration/"
           class="nav-link{% if page.url | startsWith('/validation-logic-schema-integration') %} active{% endif %}"
           {% if page.url | startsWith('/validation-logic-schema-integration') %}aria-current="page"{% endif %}>
          <span class="nav-icon">✅</span> Validation & Schema
        </a>
        <a href="/accessibility-and-error-ux/"
           class="nav-link{% if page.url | startsWith('/accessibility-and-error-ux') %} active{% endif %}"
           {% if page.url | startsWith('/accessibility-and-error-ux') %}aria-current="page"{% endif %}>
          <span class="nav-icon">♿</span> Accessibility & UX
        </a>
      </nav>
    </div>
  </header>

  {# ===== MAIN ===== #}
  <main id="main-content" class="site-main">
    {{ content | safe }}
  </main>

  {# ===== FOOTER ===== #}
  <footer class="site-footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-col footer-brand">
        <h3>ClientSideForm</h3>
        <p>Production-ready patterns for robust client-side form architecture.</p>
        <p style="margin-top:0.5rem">
          <a href="/">Home</a>
        </p>
        <p class="footer-social">
          <a href="https://github.com/client-side-form" class="footer-social-link"
             aria-label="ClientSideForm on GitHub" rel="noopener noreferrer" target="_blank">
            <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
            </svg>
            <span>GitHub</span>
          </a>
        </p>
      </div>
      <div class="footer-col">
        <h3>📐 Form State</h3>
        <ul>
          <li><a href="/form-state-fundamentals-architecture/">Overview</a></li>
          <li><a href="/form-state-fundamentals-architecture/controlled-vs-uncontrolled-forms/">Controlled vs Uncontrolled</a></li>
          <li><a href="/form-state-fundamentals-architecture/controlled-vs-uncontrolled-forms/best-practices-for-uncontrolled-form-state/">Uncontrolled Form Best Practices</a></li>
          <li><a href="/form-state-fundamentals-architecture/dirty-and-pristine-state-tracking/">Dirty &amp; Pristine Tracking</a></li>
          <li><a href="/form-state-fundamentals-architecture/dirty-and-pristine-state-tracking/how-to-track-dirty-fields-in-react-forms/">Track Dirty Fields in React</a></li>
          <li><a href="/form-state-fundamentals-architecture/dirty-and-pristine-state-tracking/implementing-pristine-state-in-vue-3/">Pristine State in Vue 3</a></li>
          <li><a href="/form-state-fundamentals-architecture/error-state-mapping-patterns/">Error State Mapping</a></li>
          <li><a href="/form-state-fundamentals-architecture/form-validation-lifecycle/">Validation Lifecycle</a></li>
          <li><a href="/form-state-fundamentals-architecture/performance-and-scale-for-large-forms/">Performance &amp; Scale</a></li>
          <li><a href="/form-state-fundamentals-architecture/submission-state-and-optimistic-updates/">Submission &amp; Optimistic Updates</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>🔌 Framework Adapters</h3>
        <ul>
          <li><a href="/framework-adapters-custom-hooks/">Overview</a></li>
          <li><a href="/framework-adapters-custom-hooks/react-form-hook-architecture/">React Hook Architecture</a></li>
          <li><a href="/framework-adapters-custom-hooks/react-form-hook-architecture/building-a-custom-useformfield-hook/">Custom useFormField Hook</a></li>
          <li><a href="/framework-adapters-custom-hooks/vue-composition-api-form-adapters/">Vue Composition API</a></li>
          <li><a href="/framework-adapters-custom-hooks/vue-composition-api-form-adapters/syncing-vue-form-state-with-pinia/">Vue Form State &amp; Pinia</a></li>
          <li><a href="/framework-adapters-custom-hooks/svelte-store-integration-for-forms/">Svelte Store Integration</a></li>
          <li><a href="/framework-adapters-custom-hooks/angular-reactive-forms-adapters/">Angular Reactive Forms</a></li>
          <li><a href="/framework-adapters-custom-hooks/hydration-sync-for-ssr-forms/">SSR Hydration Sync</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>✅ Validation &amp; Schema</h3>
        <ul>
          <li><a href="/validation-logic-schema-integration/">Overview</a></li>
          <li><a href="/validation-logic-schema-integration/integrating-zod-for-schema-validation/">Zod Integration</a></li>
          <li><a href="/validation-logic-schema-integration/integrating-zod-for-schema-validation/how-to-validate-dependent-fields-with-zod/">Validate Dependent Fields with Zod</a></li>
          <li><a href="/validation-logic-schema-integration/asynchronous-validation-strategies/">Async Validation</a></li>
          <li><a href="/validation-logic-schema-integration/asynchronous-validation-strategies/implementing-async-email-availability-checks/">Async Email Availability Checks</a></li>
          <li><a href="/validation-logic-schema-integration/cross-field-dependency-logic/">Cross-Field Logic</a></li>
          <li><a href="/validation-logic-schema-integration/synchronous-validation-patterns/">Sync Validation Patterns</a></li>
          <li><a href="/validation-logic-schema-integration/choosing-a-schema-validation-library/">Choosing a Schema Library</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h3>♿ Accessibility &amp; UX</h3>
        <ul>
          <li><a href="/accessibility-and-error-ux/">Overview</a></li>
          <li><a href="/accessibility-and-error-ux/aria-live-regions-for-form-errors/">ARIA Live Regions</a></li>
          <li><a href="/accessibility-and-error-ux/focus-management-after-validation/">Focus Management</a></li>
          <li><a href="/accessibility-and-error-ux/keyboard-navigation-patterns/">Keyboard Navigation</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; {% year %} Client-Side Form State &amp; Validation Architecture. Built with Eleventy.
    </div>
  </footer>

  <script src="/assets/js/copy-code.js?v={{ assets.copyCodeJs }}" defer></script>
  <script src="/assets/js/main.js?v={{ assets.mainJs }}" defer></script>
</body>
</html>

